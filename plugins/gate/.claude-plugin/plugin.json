{
  "name": "gate",
  "description": "cc-toolgate PreToolUse hook for Bash command validation",
  "author": {
    "name": "butterflyskies"
  },
  "license": "MIT OR Apache-2.0",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/ensure-installed.sh",
            "timeout": 120,
            "async": true,
            "statusMessage": "Checking cc-toolgate installation..."
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "cc-toolgate",
            "timeout": 5,
            "statusMessage": "Validating command..."
          }
        ]
      }
    ]
  }
}
