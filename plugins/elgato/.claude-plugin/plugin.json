{
  "name": "elgato",
  "description": "MCP wiring for Elgato Key Light control server",
  "author": {
    "name": "butterflyskies"
  },
  "license": "MIT OR Apache-2.0",
  "userConfig": {
    "elgato_repo": {
      "type": "string",
      "title": "Elgato MCP Source",
      "description": "pip-installable source for elgato-mcp (default: git+https://github.com/butterflyskies/elgato-control-home-automation)"
    }
  },
  "mcpServers": {
    "elgato-keylight": {
      "type": "stdio",
      "command": "uv",
      "args": [
        "run",
        "--from",
        "${user_config.elgato_repo}",
        "--extra",
        "mcp",
        "elgato-mcp"
      ]
    }
  }
}
